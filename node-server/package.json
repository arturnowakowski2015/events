{
    "name": "node-server",
    "version": "1.0.0",
    "description": "CarMonitoring Node.js backend",
    "main": "dist/index.js",
    "scripts": {
        "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
        "build": "tsc",
        "start": "ts-node ./index.ts",
        "migrate": "ts-node src/db/migrate.ts"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.18.2",
        "pg": "^8.11.3",
        "uuid": "^9.0.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/pg": "^8.11.2",
        "@types/uuid": "^9.0.7",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.3.3"
    }
}